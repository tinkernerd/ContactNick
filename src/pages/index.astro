---
import { Icon } from 'astro-icon/components';
import { socialLinks } from '@/site-config';  
const socialLinksArray = Object.values(socialLinks);
import { siteConfig } from "@/site-config";
import "../styles/global.css";


---

<!DOCTYPE html>
<html lang="en">
<head>
<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
<title>{siteConfig.title}</title>

<link rel="preconnect" href="https://fonts.googleapis.com" /><link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  /><link
    href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap"
    rel="stylesheet"
  />
</head>
  <body class="flex flex-col items-center justify-center min-h-screen p-4">  <!-- Full-width Background Section -->
  <section class="w-full py-12 px-6 lg:px-16">
    <div class="flex flex-col gap-12 max-w-4xl mx-auto">
      
    <!-- About Section (Left) -->
    <div class="border border-white rounded-xl p-8 w-full">
      <!-- Profile Image -->
      <div class="flex justify-center lg:justify-start mb-6">
        <img 
          src="https://gravatar.com/avatar/ab58fe7213ba269ba2cfbe70877dd318ed7b5ba64243e5c48e79c8b8c6223aae?s=200" 
          alt="Nicholas Stull" 
          class="w-40 h-40 rounded-xl object-cover shadow-md"
        />
      </div>

      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-1">Nicholas Stull • KF8FLI</h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-4">A&amp;P Student • Amateur Radio • Tech</p>

      <p class="text-base text-gray-700 dark:text-gray-300 mb-4">
        Hi, I’m Nick — KF8FLI. I’m an A&amp;P student currently in Traverse City, Michigan with a background in IT and networking.
      </p>

      <p class="text-base text-gray-700 dark:text-gray-300 mb-4">
        I enjoy portable and field‑deployable comms, Raspberry Pi hotspots, temporary repeater setups, and getting into HF radio while pursuing my General license.
      </p>

      <p class="text-base text-gray-700 dark:text-gray-300 mb-4">
        I enjoy learning, building, and experimenting at the intersection of aviation, radio, and technology — and I’m always happy to talk with others who share similar interests.
      </p>

      <p class="text-sm text-gray-500 dark:text-gray-400 italic">
        Fueled by caffeine, sarcasm, and whatever God allows today.
      </p>


      
  <!-- Social Links -->
      <div class="flex gap-4 mt-4">
        {socialLinksArray.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-600 dark:text-gray-300 hover:text-blue-500 transition-all"
            aria-label={link.title}
          >
            <Icon name={link.icon} class="w-6 h-6" />
          </a>
        ))}
      </div>
    </div>
  </section>
  </body>
</html>
